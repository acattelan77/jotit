{
  "manifest_version": 3,
  "name": "Jot it!",
  "version": "1.2.2",
  "description": "Quick notes in a side panel while you browse.",
  "minimum_chrome_version": "114",
  "action": {
    "default_title": "Jot it!",
    "default_icon": {
      "16": "icons/icon_16.png",
      "32": "icons/icon_32.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open-jot-it": {
      "description": "Open Jot it (side panel with popup fallback)"
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src http: https:; object-src 'none'; base-uri 'none'; frame-src 'none'"
  },
  "permissions": ["sidePanel", "storage", "downloads", "tabs", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-selection.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
